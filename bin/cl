#!/usr/bin/env bash
set -euo pipefail
_here="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$_here/lib/core.sh"
# Optional override hook for tests (lets a test inject a fake cl_http_get_usage).
[ -n "${CL_OVERRIDE:-}" ] && [ -f "${CL_OVERRIDE:-}" ] && source "$CL_OVERRIDE"

die() { printf 'cl: %s\n' "$*" >&2; exit 1; }

cl_usage_help() {
  cat <<'EOF'
usage:
  cl login <name>        Add a new account (opens browser OAuth)
  cl import <name>       Save current ~/.claude account as a profile
  cl use <name>          Switch active account (kills running claude first)
  cl switch              Interactive switcher (kills running claude first)
  cl kill                Kill all running claude processes
  cl list                Table of profiles: active marker, email, plan, cached usage
  cl usage [name|--all]  Live usage table for all accounts; name = one account's detail
  cl current             Print active profile
  cl remove <name>       Delete a profile
  cl export <a.tgz>      Back up all profiles
  cl restore <a.tgz>     Restore profiles from archive
  cl ps                  List running claude processes (excludes this session)
  cl doctor              Show paths, claude process state, profile summary
  cl help                Show this help

env: CL_PROFILES_DIR (default ~/.claude_auth_profiles), CL_CRED (default ~/.claude/.credentials.json),
     CL_ACCOUNT (default ~/.claude.json — holds the oauthAccount subscription identity)
EOF
}

cmd_current() {
  if [ -f "$CL_PROFILES_DIR/current" ]; then cat "$CL_PROFILES_DIR/current"; else echo "none"; fi
}

cmd_login() { # name
  local name="${1:-}"; [ -n "$name" ] || die "usage: cl login <name>"
  [ -f "$CL_CRED" ] || die "no credentials at $CL_CRED — run 'claude' first to initialise Claude Code"

  local backup="${CL_CRED}.cl_bak"
  cp "$CL_CRED" "$backup"
  rm -f "$CL_CRED"
  local acct_backup; acct_backup="$(cl_read_account "$CL_ACCOUNT")"   # restored after login

  local ok=0
  if claude auth login; then
    if [ -f "$CL_CRED" ]; then
      local oauth; oauth="$(cl_read_oauth "$CL_CRED")"
      if [ -n "$oauth" ] && [ "$oauth" != "null" ]; then
        mkdir -p "$CL_PROFILES_DIR"; chmod 700 "$CL_PROFILES_DIR" 2>/dev/null || true
        umask 077; echo "$oauth" | jq . > "$CL_PROFILES_DIR/$name.json"
        local acct; acct="$(cl_read_account "$CL_ACCOUNT")"
        [ -n "$acct" ] && echo "$acct" | jq . > "$CL_PROFILES_DIR/$name.account.json"
        echo "$name" > "$CL_PROFILES_DIR/current"
        ok=1
      fi
    fi
  fi

  cp "$backup" "$CL_CRED"; rm -f "$backup"
  [ -n "$acct_backup" ] && cl_write_account "$CL_ACCOUNT" "$acct_backup"

  [ "$ok" -eq 1 ] && echo "saved as '$name' — run 'cl use $name' to switch" \
                  || die "login did not complete or credentials were not written"
}

cmd_import() { # name
  local name="${1:-}"; [ -n "$name" ] || die "usage: cl import <name>"
  [ -f "$CL_CRED" ] || die "no credentials at $CL_CRED — log in with Claude Code first"
  local oauth; oauth="$(cl_read_oauth "$CL_CRED")"
  [ "$oauth" != "null" ] || die "no claudeAiOauth block in $CL_CRED"
  umask 077
  echo "$oauth" | jq . > "$CL_PROFILES_DIR/$name.json"
  chmod 700 "$CL_PROFILES_DIR" 2>/dev/null || true
  local acct; acct="$(cl_read_account "$CL_ACCOUNT")"
  if [ -n "$acct" ]; then echo "$acct" | jq . > "$CL_PROFILES_DIR/$name.account.json"
  else echo "cl: no oauthAccount in $CL_ACCOUNT — subscription identity not captured; 'cl use' may fall back to API billing" >&2; fi
  echo "$name" > "$CL_PROFILES_DIR/current"
  echo "imported '$name'"
}

cl_lock()   { mkdir "$CL_PROFILES_DIR/.lock" 2>/dev/null || die "another cl operation is in progress (stale lock? rm -rf $CL_PROFILES_DIR/.lock)"; }
cl_unlock() { rmdir "$CL_PROFILES_DIR/.lock" 2>/dev/null || true; }

# Stable identity key for an oauthAccount JSON: "accountUuid|organizationUuid".
# Survives token rotation (unlike refreshToken), so we can tell whether the live
# credential still belongs to a given profile's account.
cl_account_key() { # oauth_account_json
  printf '%s' "$1" | jq -r '((.accountUuid // "") + "|" + (.organizationUuid // ""))' 2>/dev/null || true
}

# Before switching, fold the live credential back into the CURRENT profile when
# it belongs to the same account (matched by cl_account_key, NOT the rotating
# refresh token). A live Claude session may have rotated the current account's
# token in CL_CRED since the last switch; saving it back keeps the profile
# current and leaves no stale copy — this closes the gap where switching
# (especially with --force) silently drops a freshly-rotated token. No-ops unless
# the live account identity matches the current profile's saved identity, so it
# can never clobber a profile with a different account.
cl_save_active_to_profile() {
  local cur cur_pf cur_apf live_acct live_key saved_key oauth
  cur="$(cat "$CL_PROFILES_DIR/current" 2>/dev/null || true)"
  [ -n "$cur" ] || return 0
  cur_pf="$CL_PROFILES_DIR/$cur.json"
  cur_apf="$CL_PROFILES_DIR/$cur.account.json"
  [ -f "$cur_pf" ] && [ -f "$cur_apf" ] && [ -f "$CL_CRED" ] || return 0
  live_acct="$(cl_read_account "$CL_ACCOUNT")"
  [ -n "$live_acct" ] && [ "$live_acct" != "null" ] || return 0
  live_key="$(cl_account_key "$live_acct")"
  saved_key="$(cl_account_key "$(cat "$cur_apf")")"
  [ -n "$live_key" ] && [ "$live_key" != "|" ] && [ "$live_key" = "$saved_key" ] || return 0
  oauth="$(cl_read_oauth "$CL_CRED")"
  [ -n "$oauth" ] && [ "$oauth" != "null" ] || return 0
  umask 077; printf '%s\n' "$oauth" | jq . > "$cur_pf"
}

cmd_use() { # name [--force|-y] [--no-kill]
  local name="" force=0 no_kill="${CL_NO_KILL:-0}" a
  for a in "$@"; do
    case "$a" in
      --force|-y|--yes) force=1 ;;
      --no-kill) no_kill=1 ;;
      -*) die "unknown flag $a" ;;
      *) name="$a" ;;
    esac
  done
  [ -n "$name" ] || die "usage: cl use <name> [--force] [--no-kill]"
  local pf="$CL_PROFILES_DIR/$name.json"
  [ -f "$pf" ] || die "no such profile: $name"
  [ -f "$CL_CRED" ] || die "no credentials at $CL_CRED — log in with Claude Code first"

  # Kill live claude first — otherwise a running session writes its cached
  # credentials back over the switch on its next API call (or rotates the token
  # mid-save). (--no-kill / CL_NO_KILL=1 to skip.)
  if [ "$no_kill" != "1" ]; then
    local killed; killed="$(cl_kill_claude)"
    [ "$killed" -gt 0 ] && echo "killed $killed running claude process(es) before switching"
  fi

  # Save-back: if the live credential still belongs to the current profile's
  # account, fold it (possibly a just-rotated token) back into that profile
  # before switching away. Runs before the guard so a freshly-rotated current
  # account still registers as saved (closes the --force token-loss gap).
  cl_save_active_to_profile

  # Guard: refuse to clobber an unsaved current account.
  local cur_rt owner
  cur_rt="$(cl_read_oauth "$CL_CRED" | jq -r '.refreshToken // empty')"
  owner="$(cl_find_profile_by_refresh "$CL_PROFILES_DIR" "$cur_rt")"
  if [ -z "$owner" ] && [ "$force" -ne 1 ]; then
    die "current account is not saved as a profile — 'cl import <name>' first, or pass --force to overwrite"
  fi

  cl_lock; trap cl_unlock EXIT
  local oauth; oauth="$(cat "$pf")"
  if cl_token_expired "$oauth"; then
    local refreshed
    if refreshed="$(cl_refresh "$oauth")"; then
      oauth="$refreshed"; echo "$oauth" | jq . > "$pf"
    else
      cl_unlock; trap - EXIT
      die "token refresh failed for '$name' — re-login in Claude Code on that account then 'cl import $name'"
    fi
  fi
  cl_merge_oauth "$CL_CRED" "$(echo "$oauth" | jq -c .)"
  local apf="$CL_PROFILES_DIR/$name.account.json"
  if [ -f "$apf" ]; then cl_write_account "$CL_ACCOUNT" "$(cat "$apf")"
  else echo "cl: no saved account identity for '$name' — re-run 'cl import $name' while logged in, or Claude Code may bill via API" >&2; fi
  echo "$name" > "$CL_PROFILES_DIR/current"
  cl_unlock; trap - EXIT
  echo "switched to '$name'"
}

cmd_list() {
  local cur="" f name found=0
  [ -f "$CL_PROFILES_DIR/current" ] && cur="$(cat "$CL_PROFILES_DIR/current")"
  for f in "$CL_PROFILES_DIR"/*.json; do
    [ -e "$f" ] || continue
    case "$f" in *.usage.json|*.account.json) continue;; esac
    if [ "$found" -eq 0 ]; then
      printf '%-9s%-13s%-23s%-7s%s\n' "CURRENT" "PROFILE" "EMAIL" "PLAN" "USAGE"
      found=1
    fi
    name="$(basename "$f" .json)"
    local mark=""; [ "$name" = "$cur" ] && mark="*"
    local sub; sub="$(jq -r '.subscriptionType // "?"' "$f")"
    local email; email="$(cl_profile_email "$CL_PROFILES_DIR" "$name")"
    local usage; usage="$(cl_usage_short "$CL_PROFILES_DIR/$name.usage.json")"
    printf '%-9s%-13s%-23s%-7s%s\n' "$mark" "$name" "$email" "$sub" "$usage"
  done
  [ "$found" -eq 1 ] || echo "no profiles — 'cl import <name>' to add one"
}

_cl_usage_one() { # name
  local name="$1"
  local pf="$CL_PROFILES_DIR/$name.json"
  [ -f "$pf" ] || { echo "  ($name: no such profile)"; return 0; }
  local oauth acc usage
  oauth="$(cat "$pf")"
  if cl_token_expired "$oauth"; then
    local r; if r="$(cl_refresh "$oauth")"; then oauth="$r"; echo "$oauth" | jq . > "$pf"; fi
  fi
  acc="$(echo "$oauth" | jq -r '.accessToken')"
  usage="$(cl_fetch_usage "$acc")"
  if echo "$usage" | jq -e '.five_hour' >/dev/null 2>&1; then
    echo "$usage" | jq . > "$CL_PROFILES_DIR/$name.usage.json"
    echo "$name:"
    cl_format_usage "$usage"
  else
    echo "$name: usage query failed: $usage"
  fi
}

# Refresh one profile's live usage into its cache. Quiet on success; warns on failure.
_cl_refresh_one() { # name
  local name="$1"
  local pf="$CL_PROFILES_DIR/$name.json" oauth acc usage
  [ -f "$pf" ] || return 0
  oauth="$(cat "$pf")"
  if cl_token_expired "$oauth"; then
    local r; if r="$(cl_refresh "$oauth")"; then oauth="$r"; echo "$oauth" | jq . > "$pf"; fi
  fi
  acc="$(echo "$oauth" | jq -r '.accessToken')"
  usage="$(cl_fetch_usage "$acc")"
  if echo "$usage" | jq -e '.five_hour' >/dev/null 2>&1; then
    echo "$usage" | jq . > "$CL_PROFILES_DIR/$name.usage.json"
  else
    echo "cl: $name: usage query failed" >&2
  fi
}

cmd_usage() { # [name|--all]
  local arg="${1:-}"
  if [ -n "$arg" ] && [ "$arg" != "--all" ]; then
    _cl_usage_one "$arg"   # a named profile: refresh one + per-bucket detail
    return
  fi
  # No arg (or --all): refresh every profile live, then show the side-by-side table.
  local f
  for f in "$CL_PROFILES_DIR"/*.json; do
    [ -e "$f" ] || continue; case "$f" in *.usage.json|*.account.json) continue;; esac
    _cl_refresh_one "$(basename "$f" .json)"
  done
  cmd_list
}

cmd_remove() { # name
  local name="${1:-}"; [ -n "$name" ] || die "usage: cl remove <name>"
  local pf="$CL_PROFILES_DIR/$name.json"
  [ -f "$pf" ] || die "no such profile: $name"
  rm -f "$pf" "$CL_PROFILES_DIR/$name.usage.json" "$CL_PROFILES_DIR/$name.account.json"
  [ "$(cmd_current)" = "$name" ] && rm -f "$CL_PROFILES_DIR/current"
  echo "removed '$name'"
}

cl_claude_running() { pgrep -x claude >/dev/null 2>&1 || pgrep -f '/claude( |$)' >/dev/null 2>&1; }

# Parent-process chain from this shell ($$) up to the root. Used so a `cl`
# invocation never kills the process tree that launched it — in a normal shell
# there's no claude ancestor (so every claude session still dies), but if cl is
# ever run from inside a claude session, that one session is spared.
cl_ancestor_pids() {
  local pid=$$ i=0 ppid
  while [ -n "$pid" ] && [ "$pid" -gt 0 ] && [ "$i" -lt 24 ]; do
    printf '%s\n' "$pid"
    ppid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')"
    [ -n "$ppid" ] || break
    [ "$ppid" = "$pid" ] && break
    pid="$ppid"; i=$((i+1))
  done
}

# PIDs of running claude processes, excluding this command's ancestor chain and
# the cl switcher itself. Claude Code caches its session in memory and writes
# .credentials.json back on its next API call, so a live process silently undoes
# a switch — kill them before switching.
cl_claude_pids() {
  local skip out pid command first base lower
  skip=" $(cl_ancestor_pids | tr '\n' ' ') "
  out="$(ps -axo pid=,command= 2>/dev/null || ps -eo pid=,args= 2>/dev/null || true)"
  [ -n "$out" ] || return 0
  while read -r pid command; do
    [ -n "${pid:-}" ] || continue
    [ -n "${command:-}" ] || continue
    case "$skip" in *" $pid "*) continue ;; esac
    lower="$(printf '%s' "$command" | tr '[:upper:]' '[:lower:]')"
    case "$lower" in *claude-auth-switcher*|*"/cl ps"*|*"/cl kill"*|*"bin/cl "*) continue ;; esac
    first="${command%% *}"; base="${first##*/}"
    case "$base" in
      claude|claude.exe|Claude) printf '%s\n' "$pid" ;;
      *) case "$lower" in
           *"/claude "*|*"/claude.exe"*|*"/.local/bin/claude"*|*"claude-code/cli"*|*"@anthropic-ai/claude-code"*)
             printf '%s\n' "$pid" ;;
         esac ;;
    esac
  done <<< "$out"
}

cl_kill_claude() {
  local pids pid count=0; local -a arr=()
  pids="$(cl_claude_pids || true)"
  [ -n "$pids" ] || { printf '0\n'; return 0; }
  while read -r pid; do [ -n "$pid" ] && arr+=("$pid"); done <<< "$pids"
  for pid in "${arr[@]}"; do
    if kill "$pid" 2>/dev/null; then count=$((count+1)); else printf 'cl: could not kill pid %s\n' "$pid" >&2; fi
  done
  if [ "$count" -gt 0 ]; then
    sleep 0.5
    for pid in "${arr[@]}"; do kill -0 "$pid" 2>/dev/null && kill -KILL "$pid" 2>/dev/null || true; done
  fi
  printf '%s\n' "$count"
}

cmd_kill() {
  local n; n="$(cl_kill_claude)"
  [ "$n" -eq 0 ] && echo "no claude processes to kill" || echo "killed $n claude process(es)"
}

cmd_ps() {
  local pids pid; pids="$(cl_claude_pids || true)"
  [ -n "$pids" ] || { echo "no claude processes (excluding this session's own tree)"; return 0; }
  printf '%-8s %s\n' "PID" "COMMAND"
  while read -r pid; do
    [ -n "$pid" ] || continue
    printf '%-8s %s\n' "$pid" "$(ps -o command= -p "$pid" 2>/dev/null | cut -c1-100)"
  done <<< "$pids"
}

cmd_switch() {
  local names=() f
  for f in "$CL_PROFILES_DIR"/*.json; do
    [ -e "$f" ] || continue; case "$f" in *.usage.json|*.account.json) continue;; esac
    names+=("$(basename "$f" .json)")
  done
  [ "${#names[@]}" -gt 0 ] || die "no profiles — 'cl import <name>' first"
  echo "select a profile:"
  local i=1 n
  for n in "${names[@]}"; do printf '  %d) %s\n' "$i" "$n"; i=$((i+1)); done
  printf 'choice: '; local sel; read -r sel
  { [ "$sel" -ge 1 ] && [ "$sel" -le "${#names[@]}" ]; } 2>/dev/null || die "invalid choice"
  cmd_use "${names[$((sel-1))]}"
}

cmd_export() { # archive.tgz
  local arc="${1:-}"; [ -n "$arc" ] || die "usage: cl export <archive.tgz>"
  ( cd "$CL_PROFILES_DIR" && tar czf "$arc" --exclude='.lock' . )
  echo "exported profiles to $arc"
}
cmd_restore() { # archive.tgz
  local arc="${1:-}"; [ -n "$arc" ] || die "usage: cl restore <archive.tgz>"
  [ -f "$arc" ] || die "no such archive: $arc"
  mkdir -p "$CL_PROFILES_DIR"; chmod 700 "$CL_PROFILES_DIR" 2>/dev/null || true
  tar xzf "$arc" -C "$CL_PROFILES_DIR"
  echo "restored profiles from $arc"
}

cmd_doctor() {
  echo "claude-auth-switcher doctor"
  echo "  profiles dir : $CL_PROFILES_DIR"
  echo "  credentials  : $CL_CRED $( [ -f "$CL_CRED" ] && echo '(present)' || echo '(MISSING)')"
  echo "  account file : $CL_ACCOUNT $( [ -f "$CL_ACCOUNT" ] && { [ -n "$(cl_read_account "$CL_ACCOUNT")" ] && echo '(oauthAccount present)' || echo '(no oauthAccount)'; } || echo '(MISSING)')"
  echo "  jq           : $(command -v jq || echo 'MISSING')"
  echo "  curl         : $(command -v curl || echo 'MISSING')"
  echo "  claude proc  : $(cl_claude_running && echo running || echo 'not running')"
  echo "  active       : $(cmd_current)"
  echo "  profiles     :"
  cmd_list | sed 's/^/    /'
}

main() {
  mkdir -p "$CL_PROFILES_DIR"
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    help|-h|--help) cl_usage_help ;;
    login)          cmd_login "$@" ;;
    import)         cmd_import "$@" ;;
    use)            cmd_use "$@" ;;
    switch)         cmd_switch ;;
    kill)           cmd_kill ;;
    ps)             cmd_ps ;;
    list|ls)        cmd_list ;;
    usage)          cmd_usage "$@" ;;
    current)        cmd_current ;;
    remove|rm)      cmd_remove "$@" ;;
    export)         cmd_export "$@" ;;
    restore)        cmd_restore "$@" ;;
    doctor)         cmd_doctor ;;
    *)              cl_usage_help ;;
  esac
}
main "$@"
